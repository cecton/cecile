{
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(gh repo:*)",
      "Bash(git remote:*)",
      "Bash(cargo check:*)",
      "Bash(cargo build:*)",
      "Bash(cargo tree:*)",
      "Bash(cargo update:*)",
      "Bash(rustup show:*)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:github.com)"
    ]
  }
}
